{
  "name": "code-alchemist-repo",
  "version": "1.1.0",
  "description": "CodeAlchemist - Distill developer coding style from Git history into Claude Code Skills (Repository package)",
  "private": true,
  "scripts": {
    "validate": "bash .agents/skills/code-alchemist/scripts/validate_skill.sh",
    "test": "bash tests/run_tests.sh 2>/dev/null || echo 'No tests directory'",
    "install:skill": "node installer/install.js"
  },
  "keywords": [
    "claude-code",
    "skill",
    "git",
    "code-style",
    "developer-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fldicoahkiin/code-alchemist.git"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
